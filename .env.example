# Supabase contact form configuration
# Use the project URL and publishable key from Supabase Project Settings > API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# The contact API route also supports these legacy/public names when already configured:
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_key
